# Environment (local, staging, production)
DJANGO_ENV=local

# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (use DATABASE_URL in Railway)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=odontoinsight
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=

# APIs
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@odontoinsight.com.br

# Redis / background jobs
REDIS_URL=redis://localhost:6379/0

# Messaging
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER=

# Static / media
STATIC_URL=/static/
MEDIA_URL=/media/
